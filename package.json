{
  "name": "chorus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "check": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "ultracite": "7.4.3"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bunx ultracite fix"
    ]
  }
}
