{
  "name": "chorus",
  "version": "0.0.6",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "bun test",
    "changeset": "changeset",
    "prepare": "lefthook install",
    "version:autobump": "bun scripts/version/autobump.ts",
    "check-types": "tsc --noEmit -p tsconfig.json && turbo run check-types",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "check": "ultracite fix"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "lefthook": "^2.1.4",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "ultracite": "^7.4.3"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
